```gitignore
# ==========================================
# Python
# ==========================================

__pycache__/
*.pyc
*.pyo
*.pyd
*.log

# ==========================================
# Virtual Environment
# ==========================================

venv/
.env/

# ==========================================
# Environment Variables
# ==========================================

.env

# ==========================================
# Jupyter Notebooks
# ==========================================

.ipynb_checkpoints/

# ==========================================
# VS Code
# ==========================================

.vscode/
# ==========================================
# Streamlit Cache
# ==========================================

.streamlit/secrets.toml

# ==========================================
# Models
# ==========================================


models/*.joblib

# ==========================================
# ChromaDB / Vector Database
# ==========================================


# ==========================================
# Generated Reports
# ==========================================

*.pdf

# ==========================================
# OS Files
# ==========================================

.DS_Store
Thumbs.db
# ==========================================
notebooks/
# ==========================================
# Temporary Files
# ==========================================

temp/
cache/
*.tmp

# ==========================================
# Build Files
# ==========================================

build/
dist/
*.egg-info/

# ==========================================
# Streamlit
# ==========================================

.streamlit/

# ==========================================
# HuggingFace Cache
# ==========================================

.huggingface/
.cache/

# ==========================================
# Logs
# ==========================================

logs/
*.log
```
